# =============================================================================
# novekai-immo-test — variables d'environnement
# =============================================================================
# Copier ce fichier en `.env` puis remplir les valeurs.
# NE JAMAIS commiter `.env` (cf. .gitignore).
#
# Dans n8n self-hosted (Docker), ces variables se passent au conteneur via
# l'option `--env-file .env` ou via la section `environment:` du compose.
# Dans n8n Cloud, on les configure via Settings > Variables.
# =============================================================================


# -- OpenAI -------------------------------------------------------------------
# Clé API obtenue sur https://platform.openai.com/api-keys
# Utilisée par le nœud `OpenAI Extract` (HTTP Request vers
# https://api.openai.com/v1/chat/completions).
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modèle utilisé. gpt-4o = bon compromis qualité / coût pour le multilingue
# FR/NL + mode JSON natif (response_format: json_object) qui garantit la
# sortie parseable au niveau API.
# Voir prompts/extraction-system-prompt.md pour la justification.
OPENAI_MODEL=gpt-4o


# -- Supabase -----------------------------------------------------------------
# URL du projet : Project Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé service role (secret !) : Project Settings > API > service_role
# IMPORTANT : cette clé bypass le RLS. Ne JAMAIS l'exposer côté client.
# Le workflow n8n l'utilise pour insérer dans `leads` et logguer.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -- Gmail (documentation seulement) -----------------------------------------
# Le compte Gmail surveillé. Les credentials OAuth2 sont stockés DANS n8n
# (Credentials > Gmail OAuth2), pas dans .env. Cette variable existe juste
# pour documenter quel compte le workflow surveille.
GMAIL_USER=leads@ton-agence.be


# -- Optionnel : alertes ------------------------------------------------------
# Webhook (Slack, Discord, n8n interne…) pour notifier les emails à
# `score_confiance < 0.3`. Non activé par défaut, mais le workflow peut
# être étendu pour pinger ici.
ALERT_WEBHOOK_URL=
